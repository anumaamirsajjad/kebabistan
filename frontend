<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kebabistan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --brown-dark:#241208;
    --brown:#3e2415;
    --brown-mid:#5c3a26;
    --beige:#f3e7d3;
    --cream:#fdf8ee;
    --gold:#c9982f;
    --gold-light:#e3bd6c;
    --text-dark:#2a1a10;
    --text-light:#f8efe0;
    --shadow: 0 20px 50px rgba(36,18,8,0.25);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Poppins',sans-serif;
    background:var(--cream);
    color:var(--text-dark);
    overflow-x:hidden;
  }
  h1,h2,h3,.brand{font-family:'Playfair Display',serif;}
  a{text-decoration:none;color:inherit;}
  ul{list-style:none;}
  img{max-width:100%;display:block;}
  .container{max-width:1200px;margin:0 auto;padding:0 24px;}
  .section-tag{
    display:inline-block;color:var(--gold);font-weight:600;letter-spacing:3px;
    text-transform:uppercase;font-size:13px;margin-bottom:14px;
  }
  .section-title{font-size:clamp(28px,4vw,46px);font-weight:700;color:var(--brown-dark);margin-bottom:18px;line-height:1.2;}
  .section-sub{color:#6b5440;max-width:600px;line-height:1.7;font-size:15.5px;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:50px;
    background:var(--gold);color:var(--brown-dark);font-weight:600;border:none;cursor:pointer;
    font-size:14px;letter-spacing:1px;text-transform:uppercase;transition:.35s ease;
  }
  .btn:hover{background:var(--gold-light);transform:translateY(-3px);box-shadow:0 10px 25px rgba(201,152,47,.4);}
  .btn-outline{background:transparent;border:1.5px solid var(--text-light);color:var(--text-light);}
  .btn-outline:hover{background:var(--text-light);color:var(--brown-dark);}

  /* ===== NAV ===== */
  nav{
    position:fixed;top:0;left:0;width:100%;z-index:1000;
    display:flex;justify-content:space-between;align-items:center;
    padding:20px 5%;transition:.4s ease;background:transparent;
  }
  nav.scrolled{background:rgba(36,18,8,.92);backdrop-filter:blur(10px);padding:14px 5%;box-shadow:0 5px 20px rgba(0,0,0,.2);}
  .brand{font-size:24px;font-weight:700;color:var(--text-light);letter-spacing:1px;}
  .brand span{color:var(--gold-light);}
  .nav-links{display:flex;gap:34px;}
  .nav-links a{color:var(--text-light);font-size:14.5px;font-weight:500;position:relative;}
  .nav-links a::after{content:'';position:absolute;bottom:-6px;left:0;width:0;height:2px;background:var(--gold-light);transition:.3s;}
  .nav-links a:hover::after{width:100%;}
  .burger{display:none;flex-direction:column;gap:5px;cursor:pointer;z-index:1100;}
  .burger span{width:26px;height:2.5px;background:var(--text-light);border-radius:2px;}

  /* ===== HERO ===== */
  .hero{
    height:100vh;position:relative;display:flex;align-items:center;justify-content:center;
    text-align:center;overflow:hidden;
  }
  .hero-bg{
    position:absolute;inset:0;width:100%;height:120%;
    background:url('https://images.unsplash.com/photo-1555939594-58d7cb561ad1?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    z-index:0;
  }
  .hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(36,18,8,.55),rgba(36,18,8,.85));z-index:1;}
  .hero-content{position:relative;z-index:2;color:var(--text-light);padding:0 20px;}
  .hero-content .section-tag{color:var(--gold-light);}
  .hero-content h1{font-size:clamp(42px,8vw,96px);font-weight:800;line-height:1.05;margin-bottom:18px;}
  .hero-content h1 em{color:var(--gold-light);font-style:normal;}
  .hero-content p{font-size:17px;max-width:520px;margin:0 auto 34px;opacity:.9;line-height:1.7;}
  .hero-btns{display:flex;gap:18px;justify-content:center;flex-wrap:wrap;}
  .scroll-indicator{
    position:absolute;bottom:34px;left:50%;transform:translateX(-50%);z-index:2;
    color:var(--text-light);font-size:12px;letter-spacing:2px;text-transform:uppercase;
    display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.8;
  }
  .scroll-line{width:1px;height:40px;background:var(--gold-light);position:relative;overflow:hidden;}
  .scroll-line::after{content:'';position:absolute;top:0;left:0;width:100%;height:50%;background:var(--text-light);animation:scrollMove 1.8s infinite;}
  @keyframes scrollMove{0%{transform:translateY(-100%);}100%{transform:translateY(200%);}}

  /* ===== ABOUT ===== */
  .about{padding:130px 0;background:var(--cream);}
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:center;}
  .about-imgs{position:relative;height:460px;}
  .about-imgs img{position:absolute;border-radius:14px;object-fit:cover;box-shadow:var(--shadow);}
  .about-img-1{width:70%;height:75%;top:0;left:0;z-index:2;}
  .about-img-2{width:55%;height:55%;bottom:0;right:0;border:8px solid var(--cream);z-index:1;}
  .about-stats{display:flex;gap:40px;margin-top:36px;}
  .stat-num{font-size:34px;font-weight:800;color:var(--gold);font-family:'Playfair Display',serif;}
  .stat-label{font-size:13px;color:#6b5440;text-transform:uppercase;letter-spacing:1px;}

  /* ===== MENU ===== */
  .menu{padding:130px 0;background:var(--brown-dark);color:var(--text-light);}
  .menu .section-sub{color:#cdb89e;}
  .menu-head{text-align:center;margin-bottom:60px;}
  .menu-head .section-sub{margin:0 auto;}
  .menu-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}
  .menu-card{
    position:relative;border-radius:16px;overflow:hidden;height:340px;cursor:pointer;
    box-shadow:0 15px 35px rgba(0,0,0,.35);
  }
  .menu-card img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease;}
  .menu-card-overlay{
    position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(36,18,8,.95));
    display:flex;flex-direction:column;justify-content:flex-end;padding:26px;transition:.4s;
  }
  .menu-card h3{font-size:21px;color:var(--text-light);margin-bottom:6px;}
  .menu-card p{font-size:13px;color:var(--gold-light);opacity:0;max-height:0;transition:.4s;overflow:hidden;}
  .menu-card:hover img{transform:scale(1.12);}
  .menu-card:hover p{opacity:1;max-height:60px;margin-top:6px;}
  .menu-card-tag{
    position:absolute;top:18px;left:18px;background:var(--gold);color:var(--brown-dark);
    font-size:11px;font-weight:700;padding:5px 12px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;
  }

  /* ===== GALLERY ===== */
  .gallery{padding:130px 0;background:var(--beige);}
  .gallery-head{text-align:center;margin-bottom:50px;}
  .gallery-head .section-sub{margin:0 auto;}
  .slider-wrap{position:relative;max-width:1100px;margin:0 auto;overflow:hidden;border-radius:20px;box-shadow:var(--shadow);}
  .slider-track{display:flex;transition:transform .6s cubic-bezier(.65,0,.35,1);}
  .slide{flex:0 0 100%;height:520px;position:relative;}
  .slide img{width:100%;height:100%;object-fit:cover;}
  .slide-caption{
    position:absolute;bottom:0;left:0;right:0;padding:30px;color:#fff;
    background:linear-gradient(180deg,transparent,rgba(0,0,0,.7));font-family:'Playfair Display',serif;font-size:22px;
  }
  .slider-btn{
    position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;border-radius:50%;
    background:rgba(255,255,255,.85);border:none;cursor:pointer;font-size:18px;color:var(--brown-dark);
    z-index:5;transition:.3s;display:flex;align-items:center;justify-content:center;
  }
  .slider-btn:hover{background:var(--gold);color:#fff;}
  .slider-prev{left:18px;}
  .slider-next{right:18px;}
  .slider-dots{display:flex;justify-content:center;gap:10px;margin-top:22px;}
  .dot{width:9px;height:9px;border-radius:50%;background:#c9b79b;cursor:pointer;transition:.3s;}
  .dot.active{background:var(--gold);width:26px;border-radius:5px;}

  /* ===== RESERVATION ===== */
  .reservation{
    padding:130px 0;background:url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1600&q=80') center/cover fixed;
    position:relative;
  }
  .reservation::before{content:'';position:absolute;inset:0;background:rgba(36,18,8,.82);}
  .res-grid{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1.1fr;gap:60px;align-items:center;}
  .res-grid .section-tag{color:var(--gold-light);}
  .res-grid h2{color:var(--text-light);}
  .res-grid p{color:#dcc9b0;line-height:1.8;}
  .res-perks{margin-top:30px;display:flex;flex-direction:column;gap:14px;}
  .res-perks li{display:flex;align-items:center;gap:12px;color:var(--text-light);font-size:14.5px;}
  .res-perks svg{flex-shrink:0;color:var(--gold-light);}
  .res-form{
    background:var(--cream);border-radius:18px;padding:42px;box-shadow:var(--shadow);
  }
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
  .form-group{display:flex;flex-direction:column;gap:6px;}
  .form-group label{font-size:12.5px;font-weight:600;color:var(--brown);text-transform:uppercase;letter-spacing:.5px;}
  .form-group input,.form-group select{
    padding:13px 14px;border:1.5px solid #e3d6bd;border-radius:10px;font-family:inherit;font-size:14px;
    background:#fff;color:var(--text-dark);outline:none;transition:.3s;
  }
  .form-group input:focus,.form-group select:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,152,47,.15);}
  .res-form .btn{width:100%;justify-content:center;margin-top:10px;}
  .form-msg{margin-top:14px;font-size:13.5px;text-align:center;font-weight:600;min-height:18px;}

  /* ===== TESTIMONIALS ===== */
  .testimonials{padding:130px 0;background:var(--cream);text-align:center;}
  .testimonials .section-sub{margin:0 auto;}
  .test-wrap{max-width:720px;margin:60px auto 0;position:relative;min-height:220px;}
  .test-slide{position:absolute;inset:0;opacity:0;transition:.6s ease;pointer-events:none;}
  .test-slide.active{opacity:1;pointer-events:auto;}
  .stars{color:var(--gold);font-size:18px;margin-bottom:18px;letter-spacing:3px;}
  .test-text{font-size:19px;font-style:italic;line-height:1.8;color:var(--brown);margin-bottom:24px;font-family:'Playfair Display',serif;}
  .test-person img{width:56px;height:56px;border-radius:50%;object-fit:cover;margin:0 auto 10px;border:3px solid var(--gold-light);}
  .test-name{font-weight:700;color:var(--brown-dark);}
  .test-role{font-size:12.5px;color:#8a7158;}
  .test-nav{display:flex;justify-content:center;gap:10px;margin-top:34px;}

  /* ===== LOCATIONS ===== */
  .locations{padding:130px 0;background:var(--beige);}
  .loc-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:40px;}
  .loc-list{display:flex;flex-direction:column;gap:18px;}
  .loc-card{
    background:#fff;border-radius:14px;padding:22px;cursor:pointer;border:2px solid transparent;
    transition:.3s;box-shadow:0 8px 22px rgba(36,18,8,.08);
  }
  .loc-card.active{border-color:var(--gold);}
  .loc-card h3{font-size:18px;margin-bottom:6px;color:var(--brown-dark);}
  .loc-card p{font-size:13.5px;color:#7a6248;line-height:1.6;}
  .loc-map{border-radius:14px;overflow:hidden;box-shadow:var(--shadow);min-height:420px;}
  .loc-map iframe{width:100%;height:100%;min-height:420px;border:0;}

  /* ===== CONTACT ===== */
  .contact{padding:120px 0;background:var(--brown-dark);color:var(--text-light);text-align:center;}
  .contact .section-sub{color:#cdb89e;margin:0 auto;}
  .contact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:54px;}
  .contact-card{
    background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:16px;
    padding:36px 20px;transition:.35s;
  }
  .contact-card:hover{background:rgba(201,152,47,.12);transform:translateY(-6px);border-color:var(--gold);}
  .contact-icon{
    width:54px;height:54px;border-radius:50%;background:var(--gold);display:flex;align-items:center;
    justify-content:center;margin:0 auto 16px;color:var(--brown-dark);
  }
  .contact-card h4{font-size:16px;margin-bottom:6px;}
  .contact-card p{font-size:14px;color:#cdb89e;}
  .social-row{display:flex;gap:16px;justify-content:center;margin-top:50px;}
  .social-row a{
    width:46px;height:46px;border-radius:50%;border:1.5px solid var(--gold-light);
    display:flex;align-items:center;justify-content:center;color:var(--gold-light);transition:.3s;
  }
  .social-row a:hover{background:var(--gold-light);color:var(--brown-dark);transform:translateY(-4px);}

  /* ===== FOOTER ===== */
  footer{background:#1a0e06;color:#cdb89e;padding:70px 0 26px;}
  .foot-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:40px;margin-bottom:50px;}
  .foot-grid h4{color:var(--text-light);font-size:16px;margin-bottom:18px;font-family:'Playfair Display',serif;}
  .foot-grid p{font-size:14px;line-height:1.8;}
  .foot-links{display:flex;flex-direction:column;gap:10px;}
  .foot-links a{font-size:14px;transition:.3s;}
  .foot-links a:hover{color:var(--gold-light);padding-left:4px;}
  .foot-bottom{
    border-top:1px solid rgba(255,255,255,.08);padding-top:24px;display:flex;
    justify-content:space-between;font-size:12.5px;flex-wrap:wrap;gap:10px;
  }

  /* ===== REVEAL ANIM BASE ===== */
  .reveal{opacity:0;transform:translateY(50px);}

  /* ===== RESPONSIVE ===== */
  @media(max-width:900px){
    .nav-links{display:none;}
    .burger{display:flex;}
    .about-grid,.res-grid,.loc-grid{grid-template-columns:1fr;}
    .menu-grid{grid-template-columns:repeat(2,1fr);}
    .contact-grid{grid-template-columns:1fr;}
    .foot-grid{grid-template-columns:1fr 1fr;}
    .about-imgs{height:340px;margin-bottom:10px;}
    .form-row{grid-template-columns:1fr;}
  }
  @media(max-width:560px){
    .menu-grid{grid-template-columns:1fr;}
    .foot-grid{grid-template-columns:1fr;}
    .hero-btns{flex-direction:column;}
  }

  .mobile-menu{
    position:fixed;top:0;right:-100%;width:75%;max-width:320px;height:100vh;background:var(--brown-dark);
    z-index:1050;padding:90px 30px;transition:.4s ease;box-shadow:-10px 0 30px rgba(0,0,0,.3);
  }
  .mobile-menu.open{right:0;}
  .mobile-menu a{display:block;color:var(--text-light);font-size:18px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.08);}
</style>
</head>
<body>

<nav id="nav">
  <div class="brand">Kebab<span>istan</span></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#menu">Menu</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#reservation">Reserve</a></li>
    <li><a href="#testimonials">Reviews</a></li>
    <li><a href="#locations">Locations</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="burger" id="burger"><span></span><span></span><span></span></div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="#about">About</a>
  <a href="#menu">Menu</a>
  <a href="#gallery">Gallery</a>
  <a href="#reservation">Reserve</a>
  <a href="#testimonials">Reviews</a>
  <a href="#locations">Locations</a>
  <a href="#contact">Contact</a>
</div>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="section-tag">Est. 2009 · Modern Kebab House</span>
    <h1>Fire, Spice <br><em>& Soul</em></h1>
    <p>Handcrafted kebabs and grills, slow-marinated overnight and finished over open flame — a taste of tradition reimagined.</p>
    <div class="hero-btns">
      <a href="#reservation" class="btn">Reserve a Table</a>
      <a href="#menu" class="btn btn-outline">Explore Menu</a>
    </div>
  </div>
  <div class="scroll-indicator"><span>Scroll</span><div class="scroll-line"></div></div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="container about-grid">
    <div class="about-imgs reveal">
      <img class="about-img-1" src="https://images.unsplash.com/photo-1529193591184-b1d58069ecdd?auto=format&fit=crop&w=800&q=80" alt="Chef preparing kebab">
      <img class="about-img-2" src="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?auto=format&fit=crop&w=600&q=80" alt="Food spread">
    </div>
    <div class="reveal">
      <span class="section-tag">Our Story</span>
      <h2 class="section-title">A Legacy Grilled to Perfection</h2>
      <p class="section-sub">For over 15 years, Kebabistan has brought together time-honoured recipes and modern culinary technique. Every skewer is hand-prepared by our master grill chefs using fresh, locally-sourced ingredients and a secret blend of spices passed down through generations.</p>
      <p class="section-sub" style="margin-top:14px;">From sizzling seekh kebabs to slow-roasted BBQ platters, we serve more than food — we serve an experience rooted in warmth and hospitality.</p>
      <div class="about-stats">
        <div><div class="stat-num">15+</div><div class="stat-label">Years of Flavor</div></div>
        <div><div class="stat-num">40k+</div><div class="stat-label">Happy Guests</div></div>
        <div><div class="stat-num">12</div><div class="stat-label">Signature Dishes</div></div>
      </div>
    </div>
  </div>
</section>

<!-- MENU -->
<section class="menu" id="menu">
  <div class="container">
    <div class="menu-head reveal">
      <span class="section-tag">What We Serve</span>
      <h2 class="section-title">Our Signature Brands</h2>
      <p class="section-sub">Explore our curated cuisine collections, each crafted with its own personality and flame.</p>
    </div>
    <div class="menu-grid">
      <div class="menu-card reveal" data-cuisine="Seekh & Tikka">
        <span class="menu-card-tag">Bestseller</span>
        <img src="https://images.unsplash.com/photo-1555126634-323283e090fa?auto=format&fit=crop&w=500&q=80" alt="Seekh kebab">
        <div class="menu-card-overlay"><h3>Seekh & Tikka</h3><p>Char-grilled minced & chunk kebabs, smoky and spiced.</p></div>
      </div>
      <div class="menu-card reveal" data-cuisine="BBQ Platters">
        <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ca4b?auto=format&fit=crop&w=500&q=80" alt="BBQ platter">
        <div class="menu-card-overlay"><h3>BBQ Platters</h3><p>Mixed grills for sharing, slow-smoked to order.</p></div>
      </div>
      <div class="menu-card reveal" data-cuisine="Shawarma & Wraps">
        <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=500&q=80" alt="Shawarma wrap">
        <div class="menu-card-overlay"><h3>Shawarma & Wraps</h3><p>Rotisserie-roasted, wrapped fresh with house sauces.</p></div>
      </div>
      <div class="menu-card reveal" data-cuisine="Biryani & Rice">
        <span class="menu-card-tag">New</span>
        <img src="https://images.unsplash.com/photo-1473093295043-cdd812d0e601?auto=format&fit=crop&w=500&q=80" alt="Biryani rice dish">
        <div class="menu-card-overlay"><h3>Biryani & Rice</h3><p>Fragrant layered rice slow-cooked with whole spice.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section class="gallery" id="gallery">
  <div class="container">
    <div class="gallery-head reveal">
      <span class="section-tag">Visual Feast</span>
      <h2 class="section-title">Inside Kebabistan</h2>
      <p class="section-sub">A glimpse of our kitchen, our flames, and the dishes that define us.</p>
    </div>
    <div class="slider-wrap reveal">
      <div class="slider-track" id="sliderTrack">
        <div class="slide"><img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ca4b?auto=format&fit=crop&w=1200&q=80" alt="Grill flames"><div class="slide-caption">Live Flame Grilling</div></div>
        <div class="slide"><img src="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?auto=format&fit=crop&w=1200&q=80" alt="Food spread on table"><div class="slide-caption">Feast for Sharing</div></div>
        <div class="slide"><img src="https://images.unsplash.com/photo-1432139509613-5c4255815697?auto=format&fit=crop&w=1200&q=80" alt="Plated dish"><div class="slide-caption">Plated with Care</div></div>
        <div class="slide"><img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80" alt="Restaurant interior"><div class="slide-caption">Our Warm Dining Room</div></div>
      </div>
      <button class="slider-btn slider-prev" id="prevBtn">&#8592;</button>
      <button class="slider-btn slider-next" id="nextBtn">&#8594;</button>
    </div>
    <div class="slider-dots" id="sliderDots"></div>
  </div>
</section>

<!-- RESERVATION -->
<section class="reservation" id="reservation">
