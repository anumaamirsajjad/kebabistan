<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
gsap.registerPlugin(ScrollTrigger);

/* NAV scroll state */
const nav = document.getElementById('nav');
window.addEventListener('scroll', ()=>{
  nav.classList.toggle('scrolled', window.scrollY > 60);
});

/* Mobile menu */
const burger = document.getElementById('burger');
const mobileMenu = document.getElementById('mobileMenu');
burger.addEventListener('click', ()=> mobileMenu.classList.toggle('open'));
mobileMenu.querySelectorAll('a').forEach(a=>a.addEventListener('click', ()=> mobileMenu.classList.remove('open')));

/* Hero parallax */
gsap.to('#heroBg', {
  yPercent: 18, ease:'none',
  scrollTrigger:{ trigger:'.hero', start:'top top', end:'bottom top', scrub:true }
});
gsap.from('.hero-content', {opacity:0, y:40, duration:1.1, ease:'power3.out', delay:.3});
gsap.from('.scroll-indicator', {opacity:0, duration:1, delay:1});

/* Generic reveal animation */
document.querySelectorAll('.reveal').forEach((el)=>{
  gsap.fromTo(el, {opacity:0, y:50}, {
    opacity:1, y:0, duration:1, ease:'power3.out',
    scrollTrigger:{ trigger:el, start:'top 85%' }
  });
});

/* Stagger menu cards */
gsap.fromTo('.menu-card', {opacity:0, y:60}, {
  opacity:1, y:0, duration:.8, stagger:.12, ease:'power3.out',
  scrollTrigger:{ trigger:'.menu-grid', start:'top 80%' }
});

/* Stagger contact cards */
gsap.fromTo('.contact-card', {opacity:0, y:40}, {
  opacity:1, y:0, duration:.7, stagger:.15, ease:'power3.out',
  scrollTrigger:{ trigger:'.contact-grid', start:'top 85%' }
});

/* ===== GALLERY SLIDER ===== */
const track = document.getElementById('sliderTrack');
const slides = track.children;
const dotsWrap = document.getElementById('sliderDots');
let current = 0;
for(let i=0;i<slides.length;i++){
  const d = document.createElement('div');
  d.className = 'dot' + (i===0?' active':'');
  d.addEventListener('click', ()=> goToSlide(i));
  dotsWrap.appendChild(d);
}
function goToSlide(i){
  current = (i+slides.length)%slides.length;
  track.style.transform = `translateX(-${current*100}%)`;
  [...dotsWrap.children].forEach((d,idx)=> d.classList.toggle('active', idx===current));
}
document.getElementById('prevBtn').addEventListener('click', ()=> goToSlide(current-1));
document.getElementById('nextBtn').addEventListener('click', ()=> goToSlide(current+1));
let sliderInterval = setInterval(()=> goToSlide(current+1), 5000);

/* ===== TESTIMONIALS ===== */
const testSlides = document.querySelectorAll('.test-slide');
const testNav = document.getElementById('testNav');
let tCurrent = 0;
testSlides.forEach((s,i)=>{
  const d = document.createElement('div');
  d.className = 'dot' + (i===0?' active':'');
  d.addEventListener('click', ()=> goToTest(i));
  testNav.appendChild(d);
});
function goToTest(i){
  testSlides[tCurrent].classList.remove('active');
  testNav.children[tCurrent].classList.remove('active');
  tCurrent = (i+testSlides.length)%testSlides.length;
  testSlides[tCurrent].classList.add('active');
  testNav.children[tCurrent].classList.add('active');
}
setInterval(()=> goToTest(tCurrent+1), 6000);

/* ===== MENU CARD CLICK -> SCROLL TO RESERVATION ===== */
document.querySelectorAll('.menu-card').forEach(card=>{
  card.addEventListener('click', ()=>{
    document.getElementById('reservation').scrollIntoView({behavior:'smooth'});
  });
});

/* ===== LOCATIONS ===== */
const locCards = document.querySelectorAll('.loc-card');
const mapFrame = document.getElementById('mapFrame');
locCards.forEach(card=>{
  card.addEventListener('click', ()=>{
    locCards.forEach(c=>c.classList.remove('active'));
    card.classList.add('active');
    const lat = card.dataset.lat, lng = card.dataset.lng;
    mapFrame.src = `https://www.google.com/maps?q=${lat},${lng}&z=14&output=embed`;
  });
});

/* ===== RESERVATION FORM ===== */
const resDate = document.getElementById('resDate');
resDate.min = new Date().toISOString().split('T')[0];

const resForm = document.getElementById('resForm');
const formMsg = document.getElementById('formMsg');
resForm.addEventListener('submit', async (e)=>{
  e.preventDefault();
  formMsg.style.color = 'var(--brown)';
  formMsg.textContent = 'Submitting your reservation...';
  const btn = resForm.querySelector('button');
  btn.disabled = true;

  try{
    // Placeholder API call — replace endpoint with your real backend
    // const res = await fetch('/api/reservations', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
    await new Promise(resolve => setTimeout(resolve, 1200)); // simulated network delay
    formMsg.style.color = '#2f7a3d';
    formMsg.textContent = "✓ Reservation request received! We'll confirm via SMS shortly.";
    resForm.reset();
    resDate.min = new Date().toISOString().split('T')[0];
  }catch(err){
    formMsg.style.color = '#b3261e';
    formMsg.textContent = 'Something went wrong. Please call us directly.';
  }finally{
    btn.disabled = false;
  }
});
</script>
